{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipHist",
  "version": "0.1.0",
  "identifier": "com.ping.cliphist",
  "build": {
    "frontendDist": "../src",
    "devtools": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ClipHist",
        "width": 400,
        "height": 500,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "clipboard-manager": {}
  }
}
